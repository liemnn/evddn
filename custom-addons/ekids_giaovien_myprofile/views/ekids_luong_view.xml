<odoo>
    <data>
        <record id="ekids_giaovien_myprofile.luong_inherit_list" model="ir.ui.view">
            <field name="name">Lương giáo viên</field>
            <field name="model">ekids.luong</field>
            <field name="arch" type="xml">
                <list create="false" delete="false" >
                    <field name="thang_id" />
                    <field name="nam_id" />
                    <field name="tong_cong" sum="Total" />
                    <field name="tong_tru" sum="Total" />
                    <field name="tong_thongtin" sum="Total"/>
                    <field name="luong" sum="Total" string="Thực lĩnh" />
                    <field name="trangthai"
                            decoration-success="trangthai == '1'"
                            decoration-danger="trangthai == '0'"/>
                </list>
            </field>
        </record>


        <record id="ekids_giaovien_myprofile.action_bangluong_action" model="ir.actions.server">
            <field name="name">Vào hồ sơ cá nhân</field>
            <field name="model_id" ref="model_ekids_luong"/>
            <field name="state">code</field>
            <field name="code">
                 action = env['ekids.luong'].action_danhsach_bangluong_giaovien()
            </field>
        </record>


    </data>
</odoo>
