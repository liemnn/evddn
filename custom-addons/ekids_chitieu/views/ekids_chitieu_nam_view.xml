<odoo>
    <data>


        <!-- explicit list view definition -->
        <record id="ekids_chitieu.chitieu_nam_kanban" model="ir.ui.view">
            <field name="name">Năm</field>
            <field name="model">ekids.chitieu_nam</field>
            <field name="arch" type="xml">
                <kanban  sample="1"  action="action_view_kanban_chitieu_thang" type="object">

                    <t t-name="kanban-box">
                        <div class="box">
                            <h2 class="title">
                                <field name="name"/>
                            </h2>

                            <div class="item-list">
                               <div class="item">
                                  <div class="item-text">Tổng thu khác</div>
                                  <div class="item-info">
                                      <field name="tong_thu" widget="integer"/>
                                  </div>
                                </div>
                                <div class="item">
                                  <div class="item-text">Tổng chi</div>
                                  <div class="item-info">
                                      <field name="tong_chi" widget="integer"/>
                                  </div>
                                </div>
                            </div>
                        </div>

                    </t>

                </kanban>
            </field>
        </record>

        <record id="ekids_chitieu.chitieu_nam_form" model="ir.ui.view">
            <field name="name">Form</field>
            <field name="model">ekids.chitieu_nam</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                           <h1> <field name="name"/></h1>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
