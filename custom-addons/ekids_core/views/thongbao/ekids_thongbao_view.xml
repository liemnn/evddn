<odoo>
    <data>

    <record id="ekids_core.view_ekids_thongbao_list" model="ir.ui.view">
        <field name="name">ekids.thongbao.list</field>
        <field name="model">ekids.thongbao</field>
        <field name="arch" type="xml">
            <list string="Danh sách Thông báo" default_order="tu_ngay desc, create_date desc" sample="1">

                <field name="create_uid" string="Người gửi" widget="many2one_avatar_user" readonly="1"/>

                <field name="name" string="Tiêu đề thông báo" class="fw-bold"/>

                <field name="tu_ngay" string="Bắt đầu"/>
                <field name="den_ngay" string="Kết thúc"/>

                <field name="trangthai" string="Trạng thái"
                       widget="badge"
                       decoration-info="trangthai == '0'"
                       decoration-success="trangthai == '1'"/>

                <field name="coso_id" optional="hide" string="Cơ sở"/>
            </list>
        </field>
    </record>

    <record id="ekids_core.ekids_thongbao_kanban" model="ir.ui.view">
        <field name="name">ekids.thongbao.kanban</field>
        <field name="model">ekids.thongbao</field>
        <field name="arch" type="xml">
            <kanban class="o_kanban_mobile" sample="1" default_order="tu_ngay desc, id desc">
                <field name="name"/>
                <field name="coso_id"/>
                <field name="tu_ngay"/>
                <field name="den_ngay"/>
                <field name="trangthai"/>
                <templates>
                    <t t-name="kanban-box">
                        <div t-attf-class="oe_kanban_global_click d-flex align-items-start p-3 border-bottom #{record.trangthai.raw_value == '0' ? 'bg-light' : 'bg-white'}">

                            <div class="me-3 mt-1">
                                <t t-if="record.trangthai.raw_value == '0'">
                                    <span class="badge rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px; background-color: #E2E8F0; color: #64748B;">
                                        <i class="fa fa-pencil fa-lg"/>
                                    </span>
                                </t>
                                <t t-if="record.trangthai.raw_value == '1'">
                                    <span class="badge rounded-circle d-flex justify-content-center align-items-center" style="width: 40px; height: 40px; background-color: #DBEAFE; color: #2563EB;">
                                        <i class="fa fa-bullhorn fa-lg"/>
                                    </span>
                                </t>
                            </div>

                            <div class="flex-grow-1 min-vw-0">

                                <div class="d-flex justify-content-between align-items-baseline mb-1">
                                    <strong class="text-truncate text-secondary" style="font-size: 0.85rem; max-width: 70%;">
                                        <field name="coso_id"/>
                                    </strong>
                                    <small t-attf-class="#{record.trangthai.raw_value == '0' ? 'fw-bold text-primary' : 'text-muted'}">
                                        <field name="tu_ngay"/>
                                    </small>
                                </div>

                                <div t-attf-class="mb-1 text-truncate #{record.trangthai.raw_value == '0' ? 'fw-bolder text-dark' : 'text-dark'}" style="font-size: 1rem;">
                                    <field name="name"/>
                                </div>

                                <div class="d-flex justify-content-between align-items-center mt-2">
                                    <div class="text-muted" style="font-size: 0.75rem;">
                                        <i class="fa fa-clock-o me-1"/> Đến: <field name="den_ngay"/>
                                    </div>
                                    <div>
                                        <field name="trangthai" widget="label_selection" options="{'classes': {'0': 'secondary', '1': 'success'}}"/>
                                    </div>
                                </div>

                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <record id="ekids_core.thongbao_form" model="ir.ui.view">
        <field name="name">ekids.thongbao.form</field>
        <field name="model">ekids.thongbao</field>
        <field name="arch" type="xml">
            <form string="Thông báo">
                <header>
                    <button name="action_gui_thongbao"
                            string="Gửi thông báo đến phụ huynh"
                            type="object"
                            class="oe_highlight"
                            invisible="trangthai == '1'"
                           />
                    <button name="action_thu_hoi_thongbao"
                            string="Thu hồi thông báo"
                            type="object"
                            class="btn-secondary"
                            invisible="trangthai == '0'"
                            confirm="Bạn có chắc chắn muốn thu hồi thông báo này? Trạng thái sẽ chuyển về 'Đang soạn thảo' và phụ huynh sẽ không thấy trên App nữa."/>

                    <field name="trangthai" widget="statusbar" statusbar_visible="0,1" clickable="1"/>
                </header>
                <sheet>
                    <widget name="web_ribbon" title="Đã gửi" bg_color="text-bg-success" invisible="trangthai == '0'"/>

                    <div class="oe_title mb-4">
                        <label for="name" string="Thông báo đến phụ huynh" class="oe_edit_only fw-bold"/>
                        <h1>
                            <field name="name" placeholder="VD: Thông báo nghỉ lễ 30/4..."/>
                        </h1>
                    </div>

                    <group>
                        <group>
                            <field name="tu_ngay" string="Thời gian áp dụng" widget="daterange" options="{'end_date_field': 'den_ngay'}"/>
                            <field name="den_ngay" invisible="1"/>
                            <field name="coso_id" invisible="1"/>
                        </group>
                        <group></group>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    </data>
</odoo>
