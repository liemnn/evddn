<odoo>
    <data>

        <record model="ir.ui.view" id="ekids_giaovien.giaovien_nguoithan_list">
            <field name="name">giaovien_nguoithan</field>
            <field name="model">ekids.giaovien_nguoithan</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                   <field name="sequence" widget="handle"/>
                   <field name="name" />
                   <field name="gioitinh" />
                   <field name="ngaysinh" />
                   <field name="tuoi" />
                   <field name="dienthoai" />
                   <field name="quanhe" />
                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="ekids_giaovien.giaovien_hoctapcongtac_list">
            <field name="name">giaovien_hoctapcongtac</field>
            <field name="model">ekids.giaovien_hoctapcongtac</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                   <field name="sequence" widget="handle"/>
                   <field name="tu_ngay" string="Từ ngày"/>
                   <field name="den_ngay" string="Đến ngày"/>
                   <field name="name" string="Nơi công tác"/>
                   <field name="chucvu" string="Chức vụ"/>
                   <field name="thanhtich" string="Thành tích"/>
                   <field name="is_tham_nien_duoccong" widget="boolean_toggle" string="Được cộng dồn thâm niên"/>
                    <field name="tham_nien" invisible="is_tham_nien_duoccong == False" string="Thâm niên"/>
                </list>
            </field>
        </record>

         <record model="ir.ui.view" id="ekids_giaovien.giaovien_khenthuong_list">
            <field name="name">giaovien_khenthuong</field>
            <field name="model">ekids.giaovien_khenthuong</field>
            <field name="arch" type="xml">
                <list editable="bottom">
                   <field name="sequence" widget="handle"/>
                   <field name="name" />
                   <field name="nam" />
                   <field name="loai"
                        decoration-success="loai == '1'"
                        decoration-danger="loai == '0'"/>
                   <field name="desc" />
                </list>
            </field>
        </record>

</data>
</odoo>
