<odoo>
  <data>

    <record id="ekids_hocsinh.hocphi_thungoai_search" model="ir.ui.view">
        <field name="name">hocphi_thungoai.search</field>
        <field name="model">ekids.hocphi_thungoai</field>
        <field name="arch" type="xml">
            <search>
                <field name="thang"/>
                <field name="nam"/>
                <field name="name"/>
                <field name="desc"/>
            </search>
        </field>
    </record>

    <record id="ekids_hocsinh.hocphi_thungoai_list" model="ir.ui.view">
        <field name="name">ekids.hocphi_thungoai.tree</field>
        <field name="model">ekids.hocphi_thungoai</field>
        <field name="arch" type="xml">
            <list limit="200" default_order="nam asc,thang asc">
                <field name="sequence" widget="handle"/>
                <field name="thang"/>
                <field name="nam"/>
                <field name="name"/>
                <field name="tien" sum="Total"/>
                <field name="desc"/>
            </list>
        </field>
    </record>

    <record id="ekids_hocsinh.hocphi_thungoai_form" model="ir.ui.view">
        <field name="name">Thông tin Học phí thu ngoài</field>
        <field name="model">ekids.hocphi_thungoai</field>
        <field name="arch" type="xml">
            <form string="Quản lý Học phí thu ngoài">
                <sheet>
                    <group>
                         <field name="coso_id" readonly="true"/>
                         <field name="name"/>
                         <field name="tien"/>
                    </group>
                    <group col="2">
                        <group>
                            <field name="thang"/>
                        </group>
                        <group>
                            <field name="nam"/>
                        </group>
                    </group>
                    <group>
                        <field name="desc"/>
                    </group>
                    <notebook>
                        <page name="hocsinh_ids" string="DANH SÁCH HỌC SINH ÁP DỤNG KHOẢN THU NÀY">
                            <field name="hocsinh_ids"
                                   domain="[('coso_id', '=', coso_id),('trangthai', '=', '1')]"
                                   context="{'default_coso_id': coso_id}"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

  </data>
</odoo>
