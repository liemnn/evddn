<odoo>
    <template id="ekids_hocsinh.action_hocphi_banin_template">
        <t t-call="web.html_container">
            <t t-call="web.basic_layout">
                <div class="page" style="font-family: Arial, sans-serif;">

                    <div class="btn-print-container" style="text-align:right; margin-bottom: 20px;">
                        <button onclick="window.print()"
                                style="width:30px; height:auto; border:0px; background:transparent;"
                                title="In báo cáo" type="button">
                            <i class="fa fa-print" style="font-size: 18px; color: #555;"></i>
                        </button>
                    </div>

                    <table width="100%" border="0">
                        <tr>
                            <td style="text-align:center;">
                                <h3 style="font-size:18px; font-weight: bold; text-transform: uppercase; margin-bottom: 15px;">
                                    BẢN XÁC NHẬN ĐÓNG HỌC PHÍ THÁNG <t t-esc="thang"/>/<t t-esc="nam"/>
                                </h3>
                            </td>
                        </tr>
                    </table>

                    <table width="100%" border="1" cellspacing="0" cellpadding="0" class="box-table">
                        <thead>
                            <tr>
                                <t t-foreach="table_data[0]" t-as="header">
                                    <th><t t-esc="header"/></th>
                                </t>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="table_data[1:]" t-as="row">
                                <tr>
                                    <t t-foreach="enumerate(row)" t-as="item">
                                        <td t-attf-class="col-#{item[0]}">
                                            <t t-esc="item[1]"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                    <style>
                        /* 1. ÉP KHỔ GIẤY A4 VÀ LỀ CHUẨN KHI IN */
                        @page {
                            size: A4;
                            margin: 10mm 10mm 10mm 10mm !important; /* Lề: Trên - Phải - Dưới - Trái */
                        }

                        /* 2. CÁC THIẾT LẬP KHI MÁY IN CHẠY (Ẩn nút, ép sát lề) */
                        @media print {
                            .btn-print-container {
                                display: none !important; /* Giấu nút In đi để không in ra giấy */
                            }
                            body, .page {
                                margin-top: 0px !important;
                                padding-top: 0px !important;
                            }
                        }

                        *:not(i) {
                            font-family: Arial, sans-serif !important;
                        }

                        .box-table {
                            border-collapse: collapse;
                        }

                        .box-table th {
                            background-color: #f2f2f2;
                            color: #212529;
                            border: 1px solid #ccc;
                            font-size: 14px;
                            height: 35px;
                            padding: 5px;
                            text-align: center;
                        }

                        .box-table td {
                            border: 1px solid #ccc;
                            font-size: 13px;
                            padding: 5px;
                        }

                        td.col-0 { width: 5%; text-align: center !important; padding: 5px !important; }
                        td.col-1 { width: 20%; text-align: left !important; padding: 5px !important; }
                        td.col-2 { width: 10%; text-align: right !important; padding: 5px !important; }
                        td.col-3 { width: 10%; text-align: right !important; padding: 5px !important; }
                        td.col-4 { width: 10%; text-align: right !important; font-weight: bold; padding: 5px !important; }
                        td.col-5 { width: 20%; padding: 5px !important; }
                        td.col-6 { width: 20%; padding: 5px !important; }

                        thead {
                            display: table-header-group;
                        }

                        .page {
                            page-break-before: always;
                            page-break-after: always;
                            page-break-inside: avoid;
                            padding: 0px;
                            margin: 0px;
                        }
                    </style>

                </div>
            </t>
        </t>
    </template>
</odoo>