<odoo>
    <record id="ekids_hocsinh.view_ekids_hocsinh_user_form" model="ir.ui.view">
        <field name="name">ekids.hocsinh.res.users.form</field>
        <field name="model">res.users</field>
        <field name="arch" type="xml">
            <form string="Cơ sở">
                <sheet>
                    <group>
                        <field name="name" string="Họ và tên (người được cấp tài khoản)" />
                        <field name="login" string="Tài khoản (nên là số điện thoại)"/>
                        <field name="password" password="True"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    

</odoo>
