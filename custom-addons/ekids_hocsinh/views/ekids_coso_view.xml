                                <div class="kh-premium-header">
                                    <div class="kh-premium-avatar">
                                        <field name="logo" widget="image"/>
                                    </div>
                                    <div class="kh-premium-title"><field name="name"/></div>
                                    <div class="kh-premium-slogan"><field name="slogan"/></div>
                                </div>

                                <div class="kh-premium-body">
                                    <div class="kh-premium-desc">
                                        (Thiết lập thông tin phục vụ quản lý học phí/học sinh của trung tâm)
                                    </div>

                                    <button class="oe_kanban_action kh-btn-action kh-btn-main"
                                            name="action_cauhinh_hocphi_dm_thu_bantru"
                                            type="object">
                                        <i class="fa fa-list-ol"></i> Danh mục các khoản thu của [Học sinh]
                                    </button>

                                    <button class="oe_kanban_action kh-btn-action kh-btn-sub"
                                            name="action_cauhinh_hocphi_dm_ca"
                                            type="object">
                                        <i class="fa fa-university"></i> Danh mục [Ca/Lớp/Dịch vụ] can thiệp
                                    </button>

                                    <button class="oe_kanban_action kh-btn-action kh-btn-sub"
                                            name="action_cauhinh_hocphi_dm_chinhsach_giam"
                                            type="object">
                                        <i class="fa fa-gift"></i> Đối tượng chính sách giảm [Học phí]
                                    </button>
                                </div>

                            </div>
                        </t>
                    </templates>
                </kanban>
            </field>
        </record>
        <record model="ir.actions.act_window" id="ekids_hocsinh.coso_cauhinh_action_window">
            <field name="name">CẤU HÌNH -CƠ SỞ</field>
            <field name="res_model">ekids.coso</field>
            <field name="context">{ 'kanban_view_ref':'ekids_hocsinh.coso_kanban_cauhinh_view'}</field>
            <field name="view_mode">kanban</field>
        </record>





  </data>
</odoo>
