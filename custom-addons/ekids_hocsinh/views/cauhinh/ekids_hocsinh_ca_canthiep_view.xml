<odoo>
  <data>

        <record id="ekids_hocsinh.hocsinh_ca_canthiep_list" model="ir.ui.view">
            <field name="name">hocsinh_ca_canthiep</field>
            <field name="model">ekids.hocsinh_ca_canthiep</field>
            <field name="arch" type="xml">
                <list>
                    <field name="sequence" widget="handle"/>
                    <field name="name"/>
                    <field name="tu" />
                    <field name="den" />
                    <field name="dm_ca_id" />
                    <field name="giaovien_id" />

                </list>
            </field>
        </record>



        <record model="ir.ui.view" id="ekids_hocsinh.hocsinh_ca_canthiep_form">
            <field name="name">hocsinh_ca_canthiep.form</field>
            <field name="model">ekids.hocsinh_ca_canthiep</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <style>
                            .ekids_custom_card {
                                background: #ffffff;
                                border-radius: 12px;
                                box-shadow: 0 2px 12px rgba(0,0,0,0.06);
                                padding: 20px;
                                height: 100%;
                                border: 1px solid #f1f5f9;
                            }
                            .ekids_card_title {
                                color: #1e3a8a; /* Màu xanh đậm giống ảnh mẫu */
                                font-size: 13px;
                                font-weight: 800;
                                text-transform: uppercase;
                                margin-bottom: 15px;
                                padding-bottom: 10px;
                                border-bottom: 2px solid #e2e8f0;
                                display: flex;
                                align-items: center;
                            }
                            .ekids_card_title i {
                                color: #6366f1; /* Icon màu tím nhạt/xanh */
                                margin-right: 8px;
                                font-size: 16px;
                            }
                            .ekids_toggle_row {
                                border: 1px dashed #cbd5e1; /* Viền đứt nét */
                                background-color: #f8fafc; /* Nền xám nhạt */
                                border-radius: 12px;
                                padding: 15px 20px;
                            }
                            .day_label {
                                font-weight: 700;
                                color: #1e293b;
                                font-size: 14px;
                            }
                        </style>

                        <div class="oe_title mb-4">
                            <h1 class="d-flex align-items-center" style="font-size: 22px; color: #334155;">
                                <field name="coso_id" readonly="1" options="{'no_open': True}" class="me-2"/>
                                <span class="text-muted mx-2 fw-light">/</span>
                                <field name="hocsinh_id" readonly="1" options="{'no_open': True}" class="text-primary"/>
                            </h1>
                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">
                                <div class="ekids_custom_card">
                                    <div class="ekids_card_title">
                                        <i class="fa fa-cube"/> Thông tin ca học
                                    </div>
                                    <group>
                                        <field name="dm_ca_id" string="Loại hình (ca) can thiệp"
                                               domain="[('coso_id','=',coso_id),('trangthai','=','1')]"
                                               context="{'default_coso_id':coso_id}"/>
                                        <field name="giaovien_id" string="Giáo viên"
                                               domain="[('coso_id','=',coso_id)]"
                                               context="{'default_coso_id':coso_id}"/>
                                        <field name="tien" string="Số tiền (VNĐ)"/>
                                    </group>
                                </div>
                            </div>

                            <div class="col-md-6 mb-3">
                                <div class="ekids_custom_card">
                                    <div class="ekids_card_title">
                                        <i class="fa fa-clock-o"/> Thời gian can thiệp/học
                                    </div>
                                    <group>
                                        <label for="tu" string="Khung giờ học"/>
                                        <div class="o_row">
                                            <field name="tu" widget="flatpickr_time" placeholder="HH:MM"/>
                                            <i class="fa fa-long-arrow-right mx-2 text-muted" aria-label="Đến" title="Đến"/>
                                            <field name="den" widget="flatpickr_time" placeholder="HH:MM"/>
                                        </div>
                                        <field name="desc" string="Ghi chú" placeholder="Nhập ghi chú (nếu có)..."/>
                                    </group>
                                </div>
                            </div>

                        </div>

                        <div class="row mt-2">
                            <div class="col-12">
                                <div class="ekids_custom_card" style="padding-bottom: 20px;">
                                    <div class="ekids_card_title" style="border-bottom: none; margin-bottom: 12px;">
                                        <i class="fa fa-calendar"/> CÁC NGÀY TRONG TUẦN THAM GIA HỌC CA NÀY
                                    </div>

                                    <div class="ekids_toggle_row d-flex justify-content-between align-items-center">
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="day_label">T2</span>
                                            <field name="t2" widget="boolean_toggle" nolabel="1"/>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="day_label">T3</span>
                                            <field name="t3" widget="boolean_toggle" nolabel="1"/>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="day_label">T4</span>
                                            <field name="t4" widget="boolean_toggle" nolabel="1"/>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="day_label">T5</span>
                                            <field name="t5" widget="boolean_toggle" nolabel="1"/>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="day_label">T6</span>
                                            <field name="t6" widget="boolean_toggle" nolabel="1"/>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="day_label">T7</span>
                                            <field name="t7" widget="boolean_toggle" nolabel="1"/>
                                        </div>
                                        <div class="d-flex align-items-center gap-2">
                                            <span class="day_label text-danger">CN</span>
                                            <field name="t8" widget="boolean_toggle" nolabel="1"/>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                    </sheet>
                </form>
            </field>
        </record>
  </data>
</odoo>