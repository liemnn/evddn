<odoo>
  <data>

        <record id="ekids_hocsinh.hocsinh_nghiphep_list" model="ir.ui.view">
            <field name="name">hocsinh_nghiphep</field>
            <field name="model">ekids.hocsinh_nghiphep</field>
            <field name="arch" type="xml">
                <list>
                    <field name="tu_ngay" width="150"/>
                    <field name="den_ngay" width="150"/>
                    <field name="is_hoantra_hocphi"
                         widget="boolean_toggle" width="50"/>
                    <field name="tyle_hoantra_hocphi" />
                    <field name="desc" />


                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="ekids_hocsinh.hocsinh_nghiphep_form">
            <field name="name">hocsinh_nghiphep_form</field>
            <field name="model">ekids.hocsinh_nghiphep</field>
            <field name="arch" type="xml">
            <form  target="new">
                <sheet>
                    <h4>
                        <field name="coso_id" readonly="true"/>/
                        <field name="hocsinh_id" readonly="true"/>
                    </h4>
                    <group col="2">
                        <group>
                            <field name="tu_ngay"/>
                        </group>
                         <group>
                            <field name="den_ngay"/>
                        </group>
                    </group>
                    <group col="2">
                         <group>
                            <field name="is_hoantra_hocphi" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="tyle_hoantra_hocphi" invisible="is_hoantra_hocphi == False" />
                        </group>

                    </group>
                    <group>

                        <field name="desc" />
                    </group>
                </sheet>
            </form>
            </field>
        </record>



  </data>
</odoo>