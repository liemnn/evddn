<odoo>
  <data>

        <record id="ekids_hocsinh.kehoach_thang_kanban_view" model="ir.ui.view">
            <field name="name">Kanban Kế hoạch [Tháng]</field>
            <field name="model">ekids.kehoach_thang</field>
            <field name="priority" eval="100"/>
            <field name="arch" type="xml">
                 <kanban
                    default_order="id asc" create="0">

                        <t t-name="kanban-box">

                            <div class="box-user" >
                                <!-- Vùng ảnh -->

                                <div class="info">
                                    <h1>
                                        <field name="name"/>
                                    </h1>

                                    <separator string="KẾ HOACH CAN THIỆP" />

                                    <div class="item-list">

                                       <div class="item">
                                          <div class="item-text">Từ ngày</div>
                                          <div class="item-info">
                                             <field name="tu_ngay"/>
                                          </div>
                                        </div>
                                        <div class="item">
                                          <div class="item-text">Đến ngày</div>
                                          <div class="item-info">
                                             <field name="den_ngay"/>
                                          </div>
                                        </div>
                                        <div class="item">
                                          <div class="item-text">Tổng mục tiêu trong tháng</div>
                                          <div class="item-info">
                                             <field name="tong_muctieu"/>
                                          </div>
                                        </div>
                                    </div>


                                </div>

                            </div>
                        </t>

                </kanban>
            </field>
        </record>

        <record id="ekids_hocsinh.kehoach_thang_form" model="ir.ui.view">
            <field name="name">Form</field>
            <field name="model">ekids.kehoach_thang</field>
            <field name="arch" type="xml">
                <form>
                     <sheet>

                        <group col="2">
                            <group>
                                <field name="tu_ngay" readonly="True"/>
                            </group>
                            <group>
                                <field name="den_ngay" readonly="True"/>
                            </group>

                        </group>
                        <notebook>
                            <page name="muctieu_ids " string="MỤC TIÊU CAN THIỆP CỦA THÁNG">
                                <field name="muctieu_ids"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>





  </data>
</odoo>