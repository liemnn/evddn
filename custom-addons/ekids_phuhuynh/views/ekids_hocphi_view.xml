<odoo>
  <data>


    <record id="ekids_phuhuynh.hocphi_kanban_view" model="ir.ui.view">
        <field name="name">ekids.hocphi.kanban.phuhuynh</field>
        <field name="model">ekids.hocphi</field>
        <field name="arch" type="xml">
            <kanban create="0" edit="0" delete="0"
                    sample="1"  action="action_in_hocphi" type="object"
                    default_order="id desc">
                <field name="thang_id"/>
                <field name="nam_id"/>
                <field name="hocsinh_id"/>
                <field name="trangthai"/>
                <field name="hocphi_phaidong"/>
                <field name="hocphi_giam"/>

                <templates>
                    <t t-name="kanban-box">
                        <style>
                            .o_kanban_record { width: 100% !important; border: none !important; background: transparent !important; padding: 0 5px !important; margin-bottom: 12px !important; }

                            /* KHUNG CHÍNH */
                            .ek-fee-row {
                                display: flex; align-items: center; justify-content: space-between;
                                background: #ffffff; border-radius: 14px; padding: 12px 15px;
                                box-shadow: 0 4px 10px rgba(0,0,0,0.03); border: 1px solid #f1f5f9;
                                position: relative; overflow: hidden; gap: 10px;
                            }

                            /* VỆT MÀU TRẠNG THÁI */
                            .ek-fee-row::before { content: ""; position: absolute; left: 0; top: 0; bottom: 0; width: 5px; }
                            .ek-fee-row.st-dangtinh::before { background: #94a3b8; }
                            .ek-fee-row.st-dakt::before { background: #3b82f6; }
                            .ek-fee-row.st-dangno::before { background: #ef4444; }
                            .ek-fee-row.st-dadong::before { background: #10b981; }

                            /* =========================================
                               VÙNG 1: THIẾT KẾ CẬP NHẬT (To tên, Đỏ năm)
                               ========================================= */
                            .ek-z1 {
                                flex: 1; min-width: 0;
                                display: flex; flex-direction: column; gap: 6px; padding-left: 5px;
                            }

                            /* Tiêu đề: Đã bỏ chữ Học phí, chỉ để tháng */
                            .ek-z1-title {
                                font-size: 16px; font-weight: 900; color: #0f172a;
                                display: flex; align-items: center; gap: 8px;
                                white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
                            }

                            .ek-z1-sub {
                                display: flex; align-items: center; gap: 12px;
                                white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
                            }

                            /* Ô nổi cho Năm - CHUYỂN SANG MÀU ĐỎ NỔI BẬT */
                            .ek-year-badge {
                                background: #fee2e2; color: #b91c1c; border: 1px solid #fecaca;
                                padding: 3px 10px; border-radius: 8px; font-size: 11px; font-weight: 800;
                                display: inline-flex; align-items: center; white-space: nowrap;
                            }

                            /* Tên học sinh - PHÓNG TO FONT CHỮ (16px) */
                            .ek-student-name {
                                font-size: 16px; font-weight: 800; color: #1e293b;
                                display: flex; align-items: center; gap: 6px;
                            }

                            /* =========================================
                               VÙNG 2: SỐ TIỀN (Giữ nguyên khóa cứng, căng phải)
                               ========================================= */
                            .ek-z2 {
                                flex: 0 0 200px;
                                display: flex; flex-direction: column; align-items: flex-end; justify-content: center;
                                padding-right: 20px;
                            }
                            .ek-z2-amount { font-size: 20px; font-weight: 900; color: #1e293b; line-height: 1.1; display: flex; align-items: baseline; gap: 4px;}
                            .ek-z2-currency { font-size: 11px; font-weight: 700; color: #94a3b8; }
                            .ek-z2-discount { font-size: 11px; font-weight: 700; color: #10b981; margin-top: 2px;}

                            /* =========================================
                               VÙNG 3: TRẠNG THÁI (Giữ nguyên khóa cứng, căng phải)
                               ========================================= */
                            .ek-z3 {
                                flex: 0 0 160px;
                                display: flex; flex-direction: column; align-items: flex-end; gap: 8px;
                                border-left: 1px dashed #e2e8f0; padding-left: 15px;
                            }
                            .ek-z3-btn {
                                background: #eff6ff; color: #3b82f6; border: none; padding: 6px 20px;
                                border-radius: 50px; font-weight: 800; font-size: 12px;
                                display: flex; align-items: center; gap: 4px; cursor: pointer; width: fit-content;
                            }

                            /* MOBILE RESPONSIVE */
                            @media (max-width: 600px) {
                                .ek-fee-row { flex-wrap: wrap; padding: 12px; gap: 10px; }
                                .ek-z1 { flex: 0 0 100%; border-bottom: 1px dashed #f1f5f9; padding-bottom: 10px; margin-bottom: 4px;}
                                .ek-student-name { font-size: 15px; } /* Thu nhỏ nhẹ trên mobile để tránh vỡ dòng */
                                .ek-z2 { flex: 1; align-items: flex-start; padding-right: 0; }
                                .ek-z3 { flex: 0 0 auto; border-left: none; padding-left: 0; align-items: flex-end;}
                            }
                        </style>

                        <t t-set="st_class" t-value="''"/>
                        <t t-if="record.trangthai.raw_value == '-1'"><t t-set="st_class" t-value="'st-dangtinh'"/></t>
                        <t t-if="record.trangthai.raw_value == '0'"><t t-set="st_class" t-value="'st-dakt'"/></t>
                        <t t-if="record.trangthai.raw_value == '2'"><t t-set="st_class" t-value="'st-dangno'"/></t>
                        <t t-if="record.trangthai.raw_value == '10' or record.trangthai.raw_value == '11'"><t t-set="st_class" t-value="'st-dadong'"/></t>

                        <div t-attf-class="ek-fee-row #{st_class}">

                            <div class="ek-z1">
                                <div class="ek-z1-title">
                                    <i class="fa fa-calendar-check-o" style="color: #3b82f6; font-size: 18px;"></i>
                                    Tháng <field name="thang_id"/>
                                </div>
                                <div class="ek-z1-sub">
                                    <div class="ek-year-badge"><field name="nam_id"/></div>
                                    <div class="ek-student-name">
                                        <i class="fa fa-user-circle-o" style="color: #94a3b8; font-size: 16px;"></i> <field name="hocsinh_id"/>
                                    </div>
                                </div>
                            </div>

                            <div class="ek-z2">
                                <div class="ek-z2-amount"><field name="hocphi_phaidong"/> <span class="ek-z2-currency">VNĐ</span></div>
                                <t t-if="record.hocphi_giam.raw_value &gt; 0">
                                    <div class="ek-z2-discount"><i class="fa fa-tag"></i> - <field name="hocphi_giam"/> đ</div>
                                </t>
                            </div>

                            <div class="ek-z3">
                                <field name="trangthai" widget="badge"
                                       decoration-muted="trangthai == '-1'"
                                       decoration-info="trangthai == '0'"
                                       decoration-danger="trangthai == '2'"
                                       decoration-success="trangthai == '10' or trangthai == '11'"/>

                                <button type="object" name="action_in_hocphi" class="ek-z3-btn">
                                    Chi tiết <i class="fa fa-angle-right"></i>
                                </button>
                            </div>

                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>


    <record id="ekids_phuhuynh.hocphi_action_server" model="ir.actions.server">
        <field name="name">Học phí</field>
        <field name="model_id" ref="model_ekids_hocphi"/>
        <field name="state">code</field>
        <field name="code">
             action = env['ekids.hocphi'].action_danhsach_hocphi_hocsinh()
        </field>
    </record>



  </data>
</odoo>