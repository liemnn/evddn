<odoo>
  <data>


    <record id="ekids_phuhuynh.thongbao_phuhuynh_list" model="ir.ui.view">
        <field name="name">Học phí</field>
        <field name="model">ekids.thongbao_phuhuynh</field>
        <field name="arch" type="xml">
            <list>
                <field name="name" />



            </list>
        </field>
    </record>

     <record model="ir.ui.view" id="ekids_phuhuynh.thongbao_phuhuynh_form">
            <field name="name">Thông báo</field>
            <field name="model">ekids.thongbao_phuhuynh</field>
            <field name="arch" type="xml">
                <form string="THÔNG BÁO TỪ - NHÀ TRƯỜNG" context="{'from_form_view':True}">
                    <sheet>
                      <group>
                             <field name="name"/>

                        </group>


                    </sheet>
                </form>
            </field>
        </record>


    <record id="ekids_phuhuynh.thongbao_action_server" model="ir.actions.server">
        <field name="name">Học phí</field>
        <field name="model_id" ref="model_ekids_thongbao_phuhuynh"/>
        <field name="state">code</field>
        <field name="code">
             action = env['ekids.thongbao_phuhuynh'].action_danhsach_thongbao_phuhuynh()
        </field>
    </record>



  </data>
</odoo>