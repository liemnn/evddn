<odoo>
  <data>


    <record id="ekids_phuhuynh.thongbao_phuhuynh_list" model="ir.ui.view">
        <field name="name">Học phí</field>
        <field name="model">ekids.thongbao_phuhuynh</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence"  />
                <field name="name" />
                <field name="is_viewed"/>


            </list>
        </field>
    </record>

     <record model="ir.ui.view" id="ekids_phuhuynh.thongbao_phuhuynh_form">
            <field name="name">Thông báo</field>
            <field name="model">ekids.thongbao_phuhuynh</field>
            <field name="arch" type="xml">
                <form string="THÔNG BÁO TỪ - NHÀ TRƯỜNG" context="{'from_form_view':True}">
                    <sheet>
                      <group>
                             <field name="name"/>

                        </group>
                        <group>
                             <field name="desc"/>

                        </group>

                    </sheet>
                </form>
            </field>
        </record>

    <record model="ir.actions.act_window" id="ekids_phuhuynh.thongbao_phuhuynh_action_window">
        <field name="name">THÔNG BÁO HỌC PHÍ</field>
        <field name="res_model">ekids.thongbao_phuhuynh</field>
        <field name="domain">[('coso_id','=', context.get('coso_id'))]</field>
        <field name="context">
            {'list_view_ref':'ekids_phuhuynh.thongbao_phuhuynh_list'
            ,'form_view_ref':'ekids_phuhuynh.thongbao_phuhuynh_form'}
        </field>
        <field name="view_mode">list,form</field>
    </record>



  </data>
</odoo>