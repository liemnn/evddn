<odoo>
    <data>
        <record id="ekids_diemdanh.chamcong_giaovien_nghiphep_wizard_form" model="ir.ui.view">
            <field name="name">chamcong_giaovien_nghiphep_wizard</field>
            <field name="model">ekids.chamcong_giaovien_nghiphep_wizard</field>
            <field name="arch" type="xml">
                <form string="Chọn ngày điểm danh">
                    <sheet>
                        <h4>
                            <field name="coso_id" readonly="true"/>/
                            <field name="giaovien_id" readonly="true"/>
                        </h4>
                        <group col="2">
                            <group>
                                <field name="tu_ngay"/>
                            </group>
                             <group>
                                <field name="den_ngay"/>
                            </group>
                        </group>

                        <group>
                            <field name="loai" />
                        </group>



                        <group>

                            <field name="desc" />
                        </group>
                    </sheet>
                    <footer>
                        <button name="action_tao_chamcong_giaovien_nghiphep"
                                type="object" string="Tạo nghỉ phép"
                                class="btn-primary"/>
                        <button string="Hủy" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>


    </data>
</odoo>
