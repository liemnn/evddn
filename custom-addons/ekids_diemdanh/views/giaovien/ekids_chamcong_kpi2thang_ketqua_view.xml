<odoo>
    <data>


        <record id="ekids_diemdanh.chamcong_kpi2thang_ketqua_list" model="ir.ui.view">
            <field name="name">chamcong_kpi2thang_ketqua</field>
            <field name="model">ekids.chamcong_kpi2thang_ketqua</field>
            <field name="arch" type="xml">
                <list editable="bottom" create="false" delete="false">

                    <field name="name" string="Tiêu chí đánh giá"
                           width="250" readonly="1" decoration-bf="1" class="text-primary"/>

                    <field name="loai_kpi" column_invisible="True" width="100"/>

                    <field name="ketqua_boolean"
                           string="Kết quả đạt được"
                           widget="boolean_toggle"
                           invisible="loai_kpi != '1'"
                           width="70"
                           class="text-end"/>

                    <field name="tong"
                           string=""
                           invisible="loai_kpi != '0'"
                           width="70"
                           class="text-start fw-bold text-success"/>

                    <field name="donvi"  width="100" string="Đơn vị" readonly="1" widget="badge" decoration-info="1"/>
                    <field name="desc" string="Ghi chú" placeholder="Nhập lý do..."/>

                </list>
            </field>
        </record>
    </data>
</odoo>
