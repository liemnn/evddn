                    <field name="d27" widget="widget_giaovien_chamcong" invisible="is_d27_nghi" width="30" />
                    <field name="d28" widget="widget_giaovien_chamcong" invisible="is_d28_nghi" width="30" />
                    <field name="d29" widget="widget_giaovien_chamcong" invisible="is_d29_nghi" width="30" />
                    <field name="d30" widget="widget_giaovien_chamcong" invisible="is_d30_nghi" width="30" />
                    <field name="d31" widget="widget_giaovien_chamcong" invisible="is_d31_nghi" width="30" />

                </list>
            </field>
        </record>
        <record id="ekids_diemdanh.chamcong_giaovien2thang_form" model="ir.ui.view">
            <field name="name">Form</field>
            <field name="model">ekids.chamcong_giaovien2thang</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <h3><field name="giaovien_id" readonly="true"/></h3>
                        </group>

                        <group col="2">

                            <group>
                                <separator string="THÔNG TIN CHẤM CÔNG TRONG THÁNG" />
                                <field name="tong_dilam_kehoach" readonly="true" string="Số ngay đi làm theo quy định"/>
                                <field name="tong_dilam_chamcong" readonly="true" string="Số ngay đi làm thực tế"/>
                                 <field name="tong_dilam_muon" readonly="true" string="Số ngay đi muộn"/>
                                <field name="tong_nghi_cangay" readonly="true" string="Số ngay nghỉ làm cả ngày"/>
                                <field name="tong_dilam_nuabuoi" readonly="true" string="Số ngay đi làm nửa ngày"/>
                                <field name="tong_nghiphep" readonly="true" string="Ngày phép xin nghỉ"/>

                            </group>
                            <group>
                                <separator string="NGÀY PHÉP GIÁO VIÊN" />
                                <field name="phep_duocphep" readonly="true" />
                                <field name="phep_da_sudung" readonly="true" />
                                <field name="phep_con_trongnam" readonly="true" />


                            </group>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>
