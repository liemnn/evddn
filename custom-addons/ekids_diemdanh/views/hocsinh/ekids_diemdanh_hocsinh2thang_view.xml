<odoo>
    <data>
         <record id="ekids_diemdanh.diemdanh_hocsinh2thang_search" model="ir.ui.view">
            <field name="name">diemdanh_hocsinh2thang.search</field>
            <field name="model">ekids.diemdanh_hocsinh2thang</field>
            <field name="arch" type="xml">
                <search>
                    <field name="hocsinh_id"/>
                </search>
            </field>
        </record>

         <record id="ekids_diemdanh.diemdanh_hocsinh2thang_list" model="ir.ui.view">
            <field name="name">Diem Danh</field>
            <field name="model">ekids.diemdanh_hocsinh2thang</field>
            <field name="arch" type="xml">
                <list  create="false" delete="true" limit="200" default_order="hocsinh_id asc">
                    <header>
                        <button name="action_xoa_taolai_diemdanh"
                            type="object"
                            string="Xóa làm lại"
                            class="btn-primary"
                            display="always"
                            confirm="Nếu bạn xác nhận toàn bộ dữ liệu điểm danh sẽ xóa toàn bộ và xác nhận lại"
                        />
                    </header>
                    <field name="sequence" width="25" />
                    <field name="hocsinh_id" width="170"  readonly="true"/>

                    <button name="action_open_popup_thongtin_diemdanh_hocsinh"
                            type="object"
                            string=""
                            width="15"
                            class="fa fa-pencil-square-o"
                            title="Xem chi tiết thông tin [Điểm danh/Học bù/Bỏ sung] của học sinh!"

                        />
                    <field name="hocbu_conlai" string="Bù" width="30"/>
                    <field name="d1" widget="widget_diemdanh_hocsinh" invisible="is_d1_nghi" width="30" />
                    <field name="d2" widget="widget_diemdanh_hocsinh" invisible="is_d2_nghi" width="30" />
                    <field name="d3" widget="widget_diemdanh_hocsinh" invisible="is_d3_nghi" width="30" />
                    <field name="d4" widget="widget_diemdanh_hocsinh" invisible="is_d4_nghi" width="30" />
                    <field name="d5" widget="widget_diemdanh_hocsinh" invisible="is_d5_nghi" width="30" />
                    <field name="d6" widget="widget_diemdanh_hocsinh" invisible="is_d6_nghi" width="30" />
                    <field name="d7" widget="widget_diemdanh_hocsinh" invisible="is_d7_nghi" width="30" />
                    <field name="d8" widget="widget_diemdanh_hocsinh" invisible="is_d8_nghi" width="30" />
                    <field name="d9" widget="widget_diemdanh_hocsinh" invisible="is_d9_nghi" width="30" />

                    <field name="d10" widget="widget_diemdanh_hocsinh" invisible="is_d10_nghi" width="30" />

                    <field name="d11" widget="widget_diemdanh_hocsinh" invisible="is_d11_nghi" width="30" />
                    <field name="d12" widget="widget_diemdanh_hocsinh" invisible="is_d12_nghi" width="30" />
                    <field name="d13" widget="widget_diemdanh_hocsinh" invisible="is_d13_nghi" width="30" />
                    <field name="d14" widget="widget_diemdanh_hocsinh" invisible="is_d14_nghi" width="30" />
                    <field name="d15" widget="widget_diemdanh_hocsinh" invisible="is_d15_nghi" width="30" />
                    <field name="d16" widget="widget_diemdanh_hocsinh" invisible="is_d16_nghi" width="30" />
                    <field name="d17" widget="widget_diemdanh_hocsinh" invisible="is_d17_nghi" width="30" />
                    <field name="d18" widget="widget_diemdanh_hocsinh" invisible="is_d18_nghi" width="30" />
                    <field name="d19" widget="widget_diemdanh_hocsinh" invisible="is_d19_nghi" width="30" />
                    <field name="d20" widget="widget_diemdanh_hocsinh" invisible="is_d20_nghi" width="30" />

                    <field name="d21" widget="widget_diemdanh_hocsinh" invisible="is_d21_nghi" width="30" />
                    <field name="d22" widget="widget_diemdanh_hocsinh" invisible="is_d22_nghi" width="30" />
                    <field name="d23" widget="widget_diemdanh_hocsinh" invisible="is_d23_nghi" width="30" />
                    <field name="d24" widget="widget_diemdanh_hocsinh" invisible="is_d24_nghi" width="30" />
                    <field name="d25" widget="widget_diemdanh_hocsinh" invisible="is_d25_nghi" width="30" />
                    <field name="d26" widget="widget_diemdanh_hocsinh" invisible="is_d26_nghi" width="30" />
                    <field name="d27" widget="widget_diemdanh_hocsinh" invisible="is_d27_nghi" width="30" />
                    <field name="d28" widget="widget_diemdanh_hocsinh" invisible="is_d28_nghi" width="30" />
                    <field name="d29" widget="widget_diemdanh_hocsinh" invisible="is_d29_nghi" width="30" />
                    <field name="d30" widget="widget_diemdanh_hocsinh" invisible="is_d30_nghi" width="30" />
                    <field name="d31" widget="widget_diemdanh_hocsinh" invisible="is_d31_nghi" width="30" />


                </list>
            </field>
        </record>

        <record id="ekids_diemdanh.diemdanh_hocsinh2thang_form" model="ir.ui.view">
            <field name="name">Form</field>
            <field name="model">ekids.diemdanh_hocsinh2thang</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <h3><field name="hocsinh_id" readonly="true"/></h3>
                        </group>
                        <group col="2">
                            <group col="1">
                                <separator string="THÔNG TIN ĐIỂM DANH TRONG THÁNG" />
                                <group>
                                    <field name="tong_dihoc_kehoach" readonly="true" string="Số ngay đi học theo quy định"/>
                                    <field name="tong_dihoc_diemdanh" readonly="true" string="Số ngay đi học thực tế"/>
                                    <field name="tong_nghi_cangay" readonly="true" string="Số ngay nghỉ học cả ngày"/>
                                    <field name="tong_dihoc_nuabuoi" readonly="true" string="Số ngay đi học nửa ngày"/>
                                    <field name="tong_nghiphep" readonly="true" string="Học sinh xin nghỉ"/>

                                </group>
                            </group>
                            <group col="1">
                                <separator string="THÔNG TIN [HỌC BÙ/TĂNG CƯỜNG] CỦA THÁNG" />
                                <group>
                                    <field name="hocbu_thangtruoc"/>
                                    <field name="hocbu_thangnay" readonly="true"/>
                                    <field name="hocbu_da_day" readonly="true"/>
                                    <field name="hocbu_conlai" readonly="true"/>
                                    <field name="tangcuong_da_day" readonly="true"/>


                                </group>
                            </group>

                        </group>

                        <notebook>
                            <page name="hocbu_thangnay_ids " string="CA [NGHỈ] ĐỢI HỌC BÙ THÁNG NÀY(-)">
                                <field name="hocbu_thangnay_ids" context="{'default_coso_id':coso_id}"/>
                            </page>
                            <page name="hocbu_da_day_ids " string="CA [ĐÃ HỌC BÙ] THÁNG NÀY(+)">
                                <field name="hocbu_da_day_ids" context="{'default_coso_id':coso_id}"/>
                            </page>
                            <page name="tangcuong_ids " string="CA [TĂNG CƯỜNG] THÁNG NÀY(+)">
                                <field name="tangcuong_ids" context="{'default_coso_id':coso_id}"/>
                            </page>
                        </notebook>
                    </sheet>
                </form>
            </field>
        </record>
    </data>
</odoo>