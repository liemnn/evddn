<odoo>
    <data>
        <record id="ekids_diemdanh.diemdanh_ngay_wizard_form" model="ir.ui.view">
            <field name="name">diemdanh_ngay_wizard</field>
            <field name="model">ekids.diemdanh_ngay_wizard</field>
            <field name="arch" type="xml">
                <form string="Chọn ngày điểm danh">
                    <group>
                        <field name="coso_id" readonly="true"/>
                        <field name="ngay"/>
                        <field name="hocsinh_ids" widget="many2many_tags"
                               domain="[('coso_id','=',coso_id),('trangthai','=','1')]"/>
                    </group>
                    <footer>
                        <button name="action_thuchien_diemdanh_ngay" type="object" string="Thực hiện" class="btn-primary"/>
                        <button string="Hủy" special="cancel" class="btn-secondary"/>
                    </footer>
                </form>
            </field>
        </record>


    </data>
</odoo>
