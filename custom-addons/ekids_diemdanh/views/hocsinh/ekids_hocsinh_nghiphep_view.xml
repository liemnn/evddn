<odoo>
  <data>
       <!-- Search view -->
        <record id="ekids_diemdanh.hocsinh_nghiphep_search" model="ir.ui.view">
          <field name="name">ekids.hocsinh_nghiphep.search</field>
          <field name="model">ekids.hocsinh_nghiphep</field>
          <field name="arch" type="xml">
            <search string="Tìm kiếm Nghỉ phép">
              <!-- Bộ lọc mặc định -->
              <filter name="filter_dang_ap_dung"
                      string="Đang áp dụng"
                      domain="[('tu_ngay','>=', context_today())]"/>

              <!-- Group By -->
              <group expand="1" string="Group By">
                <filter name="group_by_hocsinh"
                        string="Học sinh"
                        context="{'group_by':'hocsinh_id'}"/>
              </group>

              <!-- Cho phép search theo các field -->
              <field name="tu_ngay"/>
              <field name="den_ngay"/>
              <field name="hocsinh_id" string="Tên học sinh"/>
            </search>
          </field>
        </record>

        <record id="ekids_diemdanh.hocsinh_nghiphep_list" model="ir.ui.view">
            <field name="name">hocsinh_nghiphep</field>
            <field name="model">ekids.hocsinh_nghiphep</field>
            <field name="arch" type="xml">
                <list>
                    <field name="hocsinh_id" width="200"/>
                    <field name="tu_ngay"/>
                    <field name="den_ngay" />
                     <field name="is_hoantra_hocphi" widget="boolean_toggle" width="25" string="Được hoàn học phí"/>
                    <field name="tyle_hoantra_hocphi"  string="% hoàn"/>
                     <field name="desc" width="300"/>

                </list>
            </field>
        </record>

        <record model="ir.ui.view" id="ekids_diemdanh.hocsinh_nghiphep_form">
            <field name="name">hocsinh_nghiphep_form</field>
            <field name="model">ekids.hocsinh_nghiphep</field>
            <field name="arch" type="xml">
            <form  target="new">

                <sheet>
                    <field name="coso_id" readonly="true"/>
                    <group>
                        <h3>
                            <field name="hocsinh_id" placeholder="Lựa chọn học sinh nghỉ"
                                    domain="[('coso_id','=',coso_id)]"/>
                        </h3>
                    </group>

                    <group col="2">
                        <group>
                            <field name="tu_ngay"/>
                        </group>
                         <group>
                            <field name="den_ngay"/>
                        </group>
                    </group>
                    <group col="2">
                         <group>
                            <field name="is_hoantra_hocphi" widget="boolean_toggle"/>
                        </group>
                        <group>
                            <field name="tyle_hoantra_hocphi" invisible="is_hoantra_hocphi == False" />
                        </group>

                    </group>

                    <group>
                        <field name="desc" />
                    </group>
                </sheet>
            </form>
            </field>
        </record>



  </data>
</odoo>