<odoo>
    <data>
         <record id="ekids_diemdanh.diemdanh_hocsinh2ngay_list" model="ir.ui.view">
            <field name="name"> Diem Danh </field>
            <field name="model">ekids.diemdanh_hocsinh2ngay</field>
            <field name="arch" type="xml">
                <list>

                    <field name="trangthai"/>
                </list>
            </field>
        </record>



        <record id="ekids_diemdanh.diemdanh_hocsinh2ngay_form" model="ir.ui.view">
            <field name="name">Form</field>
            <field name="model">ekids.diemdanh_hocsinh2ngay</field>
            <field name="type">form</field>
            <field name="arch" type="xml">
                <form>

                    <sheet>
                        <style>
                            .ek-header-card {
                                background: #ffffff; border-radius: 20px; padding: 20px 25px;
                                display: flex; justify-content: space-between; align-items: center;
                                box-shadow: 0 4px 15px rgba(0,0,0,0.02); border: 1px solid #e2e8f0;
                                margin-bottom: 25px; flex-wrap: wrap; gap: 20px;
                            }
                            .ek-student-box { display: flex; align-items: center; gap: 15px; }
                            .ek-avatar {
                                width: 55px; height: 55px; background: #e0e7ff; color: #4f46e5;
                                border-radius: 14px; display: flex; justify-content: center; align-items: center; font-size: 26px;
                            }
                            .ek-info h2 { font-size: 22px; font-weight: 900; color: #0f172a; margin: 0; line-height: 1; }
                            .ek-date { font-size: 14px; font-weight: 700; color: #64748b; margin-top: 4px; display: flex; align-items: center; gap: 6px; }

                            /* KHAY CHỌN TRẠNG THÁI (RADIO TRAY) */
                            .ek-status-tray {
                                display: inline-flex; background: #f8fafc; border-radius: 50px; padding: 5px;
                                border: 1px solid #e2e8f0;
                            }
                            .ek-status-tray .o_field_radio { display: flex; gap: 2px; margin: 0; }
                            .ek-status-tray .o_radio_item { margin: 0 !important; }
                            .ek-status-tray input[type="radio"] { display: none !important; }
                            .ek-status-tray label {
                                display: flex !important; align-items: center; gap: 8px;
                                padding: 10px 22px; border-radius: 50px; font-size: 14px; font-weight: 700; color: #64748b;
                                background: transparent; border: none; cursor: pointer; transition: all 0.2s; margin: 0;
                            }
                            /* Hiệu ứng khi chọn (Gán màu theo logic của anh) */
                            .ek-status-tray .o_radio_item:nth-child(1) input:checked + label { background: #10b981 !important; color: #ffffff !important; box-shadow: 0 4px 10px rgba(16, 185, 129, 0.3); }
                            .ek-status-tray .o_radio_item:nth-child(2) input:checked + label { background: #f59e0b !important; color: #ffffff !important; box-shadow: 0 4px 10px rgba(245, 158, 11, 0.3); }
                            .ek-status-tray .o_radio_item:nth-child(3) input:checked + label { background: #ef4444 !important; color: #ffffff !important; box-shadow: 0 4px 10px rgba(239, 68, 68, 0.3); }

                            .ek-btn-ghost {
                                background: transparent !important; color: #ef4444 !important; border: 1.5px dashed #fca5a5 !important;
                                font-weight: 700 !important; padding: 8px 16px !important; border-radius: 10px !important; font-size: 13px !important;
                                transition: 0.2s !important; margin-top: 10px;
                            }
                            .ek-btn-ghost:hover { background: #fef2f2 !important; border-color: #ef4444 !important; }

                            @media (max-width: 768px) {
                                .ek-header-card { flex-direction: column; align-items: flex-start; }
                                .ek-status-tray { width: 100%; display: flex; }
                                .ek-status-tray .o_radio_item { flex: 1; }
                                .ek-status-tray label { justify-content: center; padding: 10px 5px; }
                            }
                        </style>

                        <div class="ek-header-card">
                            <div>
                                <div class="ek-student-box">
                                    <div class="ek-avatar"><i class="fa fa-child"></i></div>
                                    <div class="ek-info">
                                        <h2><field name="hocsinh_id" readonly="1" options="{'no_open': True}"/></h2>
                                        <div class="ek-date"><i class="fa fa-calendar-check-o"></i> <field name="ngay" readonly="1"/></div>
                                    </div>
                                </div>
                                <button name="action_quanly_nghiphep_hocsinh"
                                        string="Học sinh nghỉ phép từ ngày này (-)"
                                        type="object"
                                        context="{'default_hocsinh_id':hocsinh_id,'default_ngay':ngay}"
                                        class="ek-btn-ghost"
                                        icon="fa-plane"/>
                            </div>

                            <div>
                                <div class="ek-status-tray">
                                    <field name="trangthai" widget="radio" options="{'horizontal': true}"/>
                                </div>
                            </div>
                        </div>

                        <notebook>
                            <page string="1.XÁC NHẬN CA HỌC/NGÀY" >
                                <field name="ca2ngay_ids" >

                                    <kanban create="1" delete="1">
                                        <templates>
                                            <t t-name="kanban-box">
                                                <field name="is_hoc" invisible="1"/>
                                                <field name="is_nghi" invisible="1"/>
                                                <div class="box">                                                    <!-- Icon Section -->


                                                     <div class="item-list">
                                                        <div class="item">
                                                          <div class="item-text">Giáo viên:<field name="giaovien_id"/></div>
                                                          <div class="item-info">
                                                             <button name="action_doi_giaovien"
                                                                 class="btn-secondary"
                                                                 type="object" string="Đổi Giáo viên"
                                                                invisible="is_nghi_khongbu == True"/>

                                                          </div>
                                                        </div>

                                                        <div class="item">
                                                          <div class="item-text">Thời gian:</div>
                                                          <div class="item-info">
                                                            Từ: <field name="tu"/>
                                                            -Đến: <field name="den"/>
                                                        </div>
                                                        </div>
                                                        <div class="item">
                                                          <div class="item-text">Ca</div>
                                                          <div class="item-info">
                                                            <field name="hocphi_dm_ca_id"/>
                                                          </div>
                                                        </div>
                                                        <div class="item">
                                                          <div class="item-text">Trạng thái đã xác nhận:</div>
                                                          <div>

                                                              <field name="trangthai" widget="selection" readonly="true"
                                                                            decoration-success="trangthai in ['1', '0']"
                                                                            decoration-muted="trangthai == '2'"
                                                                            decoration-danger="trangthai == '3'"
                                                                            decoration-info="trangthai == '4'"
                                                                />
                                                          </div>
                                                        </div>

                                                         <div class="item mt-2">
                                                            <div class="item-text" style="display: flex; gap: 4px; flex-wrap: wrap;">
                                                                <button name="func_xacnhan_ca2ngay_hoc"
                                                                        class="btn-success btn-sm"
                                                                        type="object"
                                                                        string="Học"
                                                                        icon="fa-check"
                                                                        invisible="is_hoc == True"/>

                                                                <button name="func_xacnhan_ca2ngay_nghi_khongbu"
                                                                        class="btn-danger btn-sm"
                                                                        type="object"
                                                                        string="Nghỉ (Hoàn trả học phí)"
                                                                        icon="fa-times"
                                                                        invisible="is_nghi_khongbu == True"/>

                                                                <button name="func_xacnhan_ca2ngay_nghi_hocbu"
                                                                        class="btn-warning btn-sm"
                                                                        type="object"
                                                                        string="Nghỉ (Sẽ học bù)"
                                                                        icon="fa-history"
                                                                        invisible="is_nghi_hocbu == True"/>
                                                            </div>
                                                        </div>
                                                    </div>

                                                </div>

                                            </t>
                                        </templates>
                                    </kanban>

                                </field>
                            </page>
                            <page string="2. CA HOC BÙ/TĂNG CƯỜNG THÊM" >
                                 <button name="action_open_popup_tao_hocsinh2ngay_hocbu"
                                        string="Thêm (+)"
                                        type="object"
                                        context="{'is_diemdanh_hocsinh':True}"
                                        class="btn-primary"
                                />
                                <field name="ca2ngay_hocbu_ids">
                                    <kanban create="1" delete="1">
                                        <templates>
                                            <t t-name="kanban-box">
                                                <field name="is_hoc" invisible="1"/>
                                                <field name="is_nghi" invisible="1"/>
                                                <div class="box">
                                                    <!-- Icon Section -->

                                                     <div class="item-list">
                                                        <div class="item">
                                                          <div class="item-text">Giáo viên:</div>
                                                          <div class="item-info">
                                                            <field name="giaovien_id"/>
                                                          </div>
                                                        </div>
                                                        <div class="item">
                                                          <div class="item-text">Thời gian:</div>
                                                          <div class="item-info">
                                                            Từ: <field name="tu"/>
                                                            Đến: <field name="den"/>
                                                        </div>
                                                        </div>
                                                        <div class="item">
                                                          <div class="item-text">Ca</div>
                                                          <div class="item-info">
                                                            <field name="hocphi_dm_ca_id"/>
                                                          </div>
                                                        </div>
                                                        <div class="item">
                                                          <div class="item-text">Trạng thái đã xác nhận:</div>
                                                          <div>

                                                              <field name="trangthai" widget="selection" readonly="true"
                                                                            decoration-success="trangthai == '4'"
                                                                            decoration-danger="trangthai == '5'"

                                                                />
                                                          </div>
                                                        </div>
                                                         <div class="item">
                                                          <div class="item-text">
                                                               <button name="action_xoa_diemdanh_ca2ngay"
                                                                 class="btn-danger"
                                                                 type="object" string="Xóa"
                                                                       confirm="Bạn chắc chắn muốn xóa ca [Dạy bù/Tăng cường thêm] này ?"
                                                               />

                                                          </div>
                                                         </div>
                                                    </div>

                                                </div>

                                            </t>
                                        </templates>
                                    </kanban>
                                </field>
                            </page>
                        </notebook>




                        <footer>
                            <button name="action_xac_nhan"
                                    string="Xác nhận"
                                    type="object"
                                    class="btn-primary"
                            />
                            <button string="Hủy" special="cancel"
                                    class="btn-secondary"/>
                        </footer>



                    </sheet>
                </form>
            </field>
        </record>

    </data>
</odoo>
