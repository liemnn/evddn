<odoo>
    <data>
        <record id="ekids_diemdanh.diemdanh_hocsinh_nghiphep_wizard_form" model="ir.ui.view">
            <field name="name">diemdanh_hocsinh_nghiphep_wizard</field>
            <field name="model">ekids.diemdanh_hocsinh_nghiphep_wizard</field>
            <field name="arch" type="xml">
                <form string="Đăng ký nghỉ phép dài hạn">
                    <sheet>
                        <field name="coso_id" invisible="1"/>

                        <style>
                            /* BỐ CỤC WIZARD CHUNG */
                            .o_form_view .o_form_sheet_bg { padding-top: 15px !important; background: transparent !important; }
                            .o_form_sheet { border: none !important; max-width: 900px !important; margin: auto !important; padding: 0 !important; background: transparent !important;}

                            /* KHUNG BO GÓC BÊN NGOÀI */
                            .ek-w-container {
                                display: flex; flex-wrap: wrap; gap: 20px; background: #ffffff;
                                border: 1px solid #e2e8f0; border-radius: 20px; padding: 20px;
                                box-shadow: 0 4px 15px rgba(0,0,0,0.03);
                            }

                            /* ================= CỘT TRÁI ================= */
                            .ek-w-left { flex: 1; min-width: 320px; display: flex; flex-direction: column; justify-content: center; }

                            /* Header Học sinh */
                            .ek-w-header { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; }
                            .ek-w-icon {
                                width: 55px; height: 55px; background: #fee2e2; color: #ef4444; border-radius: 14px;
                                display: flex; justify-content: center; align-items: center; font-size: 24px;
                                transform: rotate(-10deg); /* Nghiêng icon máy bay nhẹ cho tự nhiên */
                            }
                            .ek-w-title { font-size: 20px; font-weight: 800; color: #0f172a; margin: 0; line-height: 1.3; }
                            .ek-w-title span { color: #3b82f6; } /* Tên học sinh màu xanh */
                            .ek-w-subtitle { font-size: 13px; font-weight: 600; color: #64748b; margin-top: 2px; }

                            /* Khung Ngày tháng */
                            .ek-w-dates {
                                background: #f8fafc; border: 1px solid #f1f5f9; border-radius: 14px;
                                padding: 15px 20px; display: flex; align-items: center; justify-content: space-between;
                            }
                            .ek-w-date-col { display: flex; flex-direction: column; gap: 4px; }
                            .ek-w-date-lbl { font-size: 10px; font-weight: 800; color: #94a3b8; text-transform: uppercase; }
                            .ek-w-date-arrow { color: #cbd5e1; font-size: 16px; }

                            /* Làm sạch thẻ Input mặc định của Odoo */
                            .ek-w-date-val input {
                                border: none !important; background: transparent !important; padding: 0 !important;
                                color: #0f172a !important; font-weight: 900 !important; font-size: 16px !important;
                                width: 100px; text-align: left; box-shadow: none !important;
                            }
                            .ek-w-date-val input:focus { outline: none !important; }

                            /* ================= CỘT PHẢI (MÀU HỒNG) ================= */
                            .ek-w-right {
                                flex: 1; min-width: 320px; background: #fffafa; border: 1px solid #fecaca; border-radius: 16px;
                                padding: 20px; display: flex; flex-direction: column;
                            }

                            /* Dòng 1: Cảnh báo  Toggle */
                            .ek-w-refund-row { display: flex; justify-content: space-between; align-items: center; }
                            .ek-w-refund-lbl { font-size: 16px; font-weight: 900; color: #b91c1c; }

                            /* Đường kẻ đứt */
                            .ek-w-divider { border-top: 1px dashed #fca5a5; margin: 15px 0; }

                            /* Dòng 2: Tỷ lệ */
                            .ek-w-ratio-row { display: flex; align-items: center; margin-bottom: 12px; gap: 6px;}
                            .ek-w-ratio-lbl { font-size: 14px; font-weight: 800; color: #991b1b; }

                            /* Input Tỷ lệ đặc biệt */
                            .ek-w-ratio-val input {
                                width: 40px; border: none !important; border-bottom: 2px dashed #fca5a5 !important;
                                background: transparent !important; color: #ef4444 !important; font-weight: 900 !important;
                                font-size: 15px !important; text-align: center; box-shadow: none !important; padding: 0 !important;
                            }

                            /* Dòng 3: Ghi chú */
                            .ek-w-desc-val textarea {
                                width: 100%; border: none !important; background: transparent !important; resize: none;
                                color: #475569 !important; font-size: 13px !important; font-weight: 500;
                                box-shadow: none !important; padding: 0 !important; margin: 0; min-height: 40px;
                            }
                            .ek-w-desc-val textarea:focus { outline: none !important; }

                            /* MOBILE RESPONSIVE */
                            @media (max-width: 650px) {
                                .ek-w-container { flex-direction: column; }
                                .ek-w-dates { flex-direction: column; text-align: center; gap: 10px; }
                                .ek-w-date-val input { text-align: center; width: 100%; }
                                .ek-w-date-arrow { transform: rotate(90deg); }
                            }
                        </style>

                        <div class="ek-w-container">

                            <div class="ek-w-left">
                                <div class="ek-w-header">
                                    <div class="ek-w-icon"><i class="fa fa-plane"></i></div>
                                    <div>
                                        <div class="ek-w-title">Học sinh: <span><field name="hocsinh_id" readonly="1" options="{'no_open': True}"/></span></div>
                                        <div class="ek-w-subtitle">Thực hiện đăng ký nghỉ phép dài hạn trong khoảng thời gian</div>
                                    </div>
                                </div>

                                <div class="ek-w-dates">
                                    <div class="ek-w-date-col">
                                        <span class="ek-w-date-lbl">Nghỉ từ ngày</span>
                                        <div class="ek-w-date-val"><field name="tu_ngay"/></div>
                                    </div>
                                    <div class="ek-w-date-arrow"><i class="fa fa-long-arrow-right"></i></div>
                                    <div class="ek-w-date-col">
                                        <span class="ek-w-date-lbl">Nghỉ đến ngày</span>
                                        <div class="ek-w-date-val"><field name="den_ngay"/></div>
                                    </div>
                                </div>
                            </div>

                            <div class="ek-w-right">
                                <div class="ek-w-refund-row">
                                    <span class="ek-w-refund-lbl">Cho phép thiết lập % hoàn trả [Học phí] riêng</span>
                                    <field name="is_hoantra_hocphi" widget="boolean_toggle"/>
                                </div>



                                <div class="ek-w-ratio-row" invisible="is_hoantra_hocphi == False">
                                    <span>Tỷ lệ % sẽ được hoàn trả [Học phí] tháng tới:</span>
                                    <div class="ek-w-ratio-val"><field name="tyle_hoantra_hocphi"/> % </div>
                                </div>
                                <div class="ek-w-divider"></div>

                                <div class="ek-w-desc-val">
                                    <field name="desc" placeholder="Ghi chú (VD: Con đi viện nhà trường đã nhận thông tin hoàn 100% học phí)..."/>
                                </div>
                            </div>

                        </div>

                    </sheet>

                    <footer style="margin-top: 15px; display: flex; justify-content: flex-end; gap: 10px; background: transparent; border: none; padding: 10px 0;">
                        <button string="Hủy" special="cancel" class="btn btn-secondary" style="border-radius: 10px; font-weight: 800; font-size: 14px; padding: 10px 25px; background: #ffffff; border: 1px solid #cbd5e1; color: #475569;"/>
                        <button name="action_tao_diemdanh_hocsinh_nghiphep" type="object" string="Tạo nghỉ phép" class="btn btn-primary" style="border-radius: 10px; font-weight: 900; font-size: 14px; padding: 10px 30px; background: #3b82f6; border: none; box-shadow: 0 4px 10px rgba(59,130,246,0.3);"/>
                    </footer>
                </form>
            </field>
        </record>


    </data>
</odoo>
