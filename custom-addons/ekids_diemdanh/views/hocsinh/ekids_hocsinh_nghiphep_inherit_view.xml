<odoo>
  <data>

        <record id="ekids_diemdanh.hocsinh_nghiphep_form_inherit" model="ir.ui.view">
          <field name="name">hocsinh_nghiphep_form</field>
          <field name="model">ekids.hocsinh_nghiphep</field>
          <field name="arch" type="xml">
              <form target="new" edit="false" create="false" delete="false">
                  <sheet>
                      <style>
                          /* BỐ CỤC CHUNG */
                          .o_form_view .o_form_sheet_bg { padding-top: 15px !important; background-color: #f4f7f9 !important; }
                          .o_form_sheet { border: none !important; max-width: 1000px !important; margin: auto !important; padding: 0 !important; background: transparent !important;}

                          .ek-w-container {
                              display: flex; flex-wrap: wrap; gap: 20px; background: #ffffff;
                              border: 1px solid #e2e8f0; border-radius: 20px; padding: 20px;
                              box-shadow: 0 4px 15px rgba(0,0,0,0.02); margin-bottom: 15px;
                          }

                          /* CỘT TRÁI */
                          .ek-w-left { flex: 1; min-width: 320px; display: flex; flex-direction: column; justify-content: center; }
                          .ek-w-header { display: flex; align-items: center; gap: 15px; margin-bottom: 20px; }
                          .ek-w-icon { width: 55px; height: 55px; background: #fee2e2; color: #ef4444; border-radius: 14px; display: flex; justify-content: center; align-items: center; font-size: 24px; transform: rotate(-10deg); }
                          .ek-w-title { font-size: 20px; font-weight: 900; color: #0f172a; margin: 0; line-height: 1.3; }
                          .ek-w-title span { color: #3b82f6; }
                          .ek-w-subtitle { font-size: 13px; font-weight: 600; color: #64748b; margin-top: 2px; }

                          .ek-w-dates { background: #f8fafc; border: 1px solid #f1f5f9; border-radius: 14px; padding: 15px 20px; display: flex; align-items: center; justify-content: space-between; }
                          .ek-w-date-col { display: flex; flex-direction: column; gap: 4px; }
                          .ek-w-date-lbl { font-size: 11px; font-weight: 800; color: #94a3b8; text-transform: uppercase; }
                          .ek-w-date-arrow { color: #cbd5e1; font-size: 18px; }

                          /* CSS Tăng size font cho Ngày tháng (18px) */
                          .ek-w-date-val input { border: none !important; background: transparent !important; padding: 0 !important; color: #0f172a !important; font-weight:bold !important; font-size: 22px !important; width: 110px; text-align: left; box-shadow: none !important; }
                          .ek-w-date-val input:focus { outline: none !important; }

                          /* CỘT PHẢI (MÀU HỒNG) */
                          .ek-w-right { flex: 1; min-width: 320px; background: #fffafa; border: 1px solid #fecaca; border-radius: 16px; padding: 20px; display: flex; flex-direction: column; justify-content: center;}
                          .ek-w-refund-row { display: flex; justify-content: space-between; align-items: center; }
                          .ek-w-refund-lbl { font-size: 16px; font-weight: 900; color: #b91c1c; }
                          .ek-w-divider { border-top: 1px dashed #fca5a5; margin: 15px 0; }
                          .ek-w-ratio-row { display: flex; align-items: center; margin-bottom: 12px; gap: 8px;}
                          .ek-w-ratio-lbl { font-size: 14px; font-weight: 800; color: #991b1b; }

                          /* CSS Tăng size font cho Tỷ lệ % (22px) */
                          .ek-w-ratio-val input { width: 55px; border: none !important; border-bottom: 2px dashed #fca5a5 !important; background: transparent !important; color: #ef4444 !important; font-weight: 900 !important; font-size: 22px !important; text-align: center; box-shadow: none !important; padding: 0 !important; }

                          .ek-w-desc-val textarea { width: 100%; border: none !important; background: transparent !important; resize: none; color: #475569 !important; font-size: 14px !important; font-weight: 500; box-shadow: none !important; padding: 0 !important; margin: 0; min-height: 40px; }
                          .ek-w-desc-val textarea:focus { outline: none !important; }

                          @media (max-width: 768px) {
                              .ek-w-container { flex-direction: column; }
                          }
                      </style>

                      <div class="ek-w-container">
                          <div class="ek-w-left">
                              <div class="ek-w-header">
                                  <div class="ek-w-icon"><i class="fa fa-plane"></i></div>
                                  <div>
                                      <div class="ek-w-title">Học sinh: <span><field name="hocsinh_id" readonly="1" options="{'no_open': True}"/></span></div>
                                      <div class="ek-w-subtitle">Chi tiết ngày nghỉ phép dài hạn</div>
                                  </div>
                              </div>

                              <div class="ek-w-dates">
                                  <div class="ek-w-date-col">
                                      <span class="ek-w-date-lbl">Nghỉ từ ngày</span>
                                      <div class="ek-w-date-val"><field name="tu_ngay"/></div>
                                  </div>
                                  <div class="ek-w-date-arrow"><i class="fa fa-long-arrow-right"></i></div>
                                  <div class="ek-w-date-col">
                                      <span class="ek-w-date-lbl">Nghỉ đến ngày</span>
                                      <div class="ek-w-date-val"><field name="den_ngay"/></div>
                                  </div>
                              </div>

                              <div style="margin-top: 15px;">
                                  <button name="action_xoa_hocsinh_nghiphep" type="object" class="btn btn-outline-danger btn-sm" icon="fa-trash" string="Hủy đăng ký nghỉ này" confirm="Bạn chắc chắn muốn hủy/xóa ngày đăng ký nghỉ phép này của Học sinh?" style="border-radius: 8px; font-weight: 800; padding: 6px 15px; font-size: 13px;"/>
                              </div>
                          </div>

                          <div class="ek-w-right">
                              <div class="ek-w-refund-row">
                                  <span class="ek-w-refund-lbl">Cho phép thiết lập % hoàn trả [Học phí] riêng</span>
                                  <field name="is_hoantra_hocphi" widget="boolean_toggle"/>
                              </div>
                              <div class="ek-w-divider"></div>
                              <div class="ek-w-ratio-row" invisible="is_hoantra_hocphi == False">
                                  <span class="ek-w-ratio-lbl">Tỷ lệ % sẽ được hoàn trả [Học phí] tháng tới:</span>
                                  <div class="ek-w-ratio-val"><b><field name="tyle_hoantra_hocphi"/>%</b></div>
                              </div>
                              <div class="ek-w-desc-val">
                                  <field name="desc" placeholder="Ghi chú (Lý do nghỉ, v.v.)..."/>
                              </div>
                          </div>
                      </div>

                      <notebook>
                          <page string="THÔNG TIN XÁC NHẬN CA/DỊCH VỤ TRONG NGÀY NGHỈ PHÉP" >
                              <field name="ca2ngay_ids" >
                                  <kanban create="1" delete="1">
                                      <templates>
                                          <t t-name="kanban-box">
                                              <field name="is_hoc" invisible="1"/>
                                              <field name="is_nghi" invisible="1"/>
                                              <field name="is_nghi_khongbu" invisible="1"/>
                                              <field name="is_nghi_hocbu" invisible="1"/>

                                              <div class="box">
                                                   <div class="item-list">
                                                      <div class="item">
                                                        <div class="item-text">Giáo viên:<field name="giaovien_id"/></div>
                                                        <div class="item-info">
                                                           <button name="action_doi_giaovien"
                                                               class="btn-secondary"
                                                               type="object" string="Đổi Giáo viên"
                                                              invisible="is_nghi_khongbu == True"/>
                                                        </div>
                                                      </div>

                                                      <div class="item">
                                                        <div class="item-text">Thời gian:</div>
                                                        <div class="item-info">
                                                          Từ: <field name="tu"/>
                                                          -Đến: <field name="den"/>
                                                      </div>
                                                      </div>

                                                      <div class="item">
                                                        <div class="item-text">Ca</div>
                                                        <div class="item-info">
                                                          <field name="hocphi_dm_ca_id"/>
                                                        </div>
                                                      </div>

                                                      <div class="item">
                                                        <div class="item-text">Trạng thái đã xác nhận:</div>
                                                        <div>
                                                            <field name="trangthai" widget="selection" readonly="true"
                                                                          decoration-success="trangthai in ['1', '0']"
                                                                          decoration-muted="trangthai == '2'"
                                                                          decoration-danger="trangthai == '3'"
                                                                          decoration-info="trangthai == '4'"
                                                              />
                                                        </div>
                                                      </div>

                                                       <div class="item">
                                                          <div class="item-text">
                                                              <button name="func_xacnhan_ca2ngay_hoc"
                                                                      class="btn-success"
                                                                      type="object"
                                                                      string="Học"
                                                                      icon="fa-check-circle"
                                                                      invisible="is_hoc == True"/>

                                                              <button name="func_xacnhan_ca2ngay_nghi_khongbu"
                                                                      class="btn-danger"
                                                                      type="object"
                                                                      string="Nghỉ (Hoàn trả học phí)"
                                                                      icon="fa-times-circle"
                                                                      invisible="is_nghi_khongbu == True"/>

                                                              <button name="func_xacnhan_ca2ngay_nghi_hocbu"
                                                                      class="btn-warning"
                                                                      type="object"
                                                                      string="Nghỉ (Sẽ học bù)"
                                                                      icon="fa-calendar-plus-o"
                                                                      invisible="is_nghi_hocbu == True"/>
                                                          </div>
                                                      </div>
                                                  </div>
                                              </div>
                                          </t>
                                      </templates>
                                  </kanban>
                              </field>
                          </page>
                      </notebook>
                  </sheet>
              </form>
          </field>
      </record>



  </data>
</odoo>