<odoo>
    <template id="ekids_baocao.baocao_nguonluc_template">
        <t t-call="web.html_container">

            <t t-call="web.basic_layout">

                <div class="page" style="font-family: Arial, sans-serif; color: #333;">

                     <div class="btn-print-container" style="text-align:right; margin-bottom: 20px;">
                        <button onclick="window.print()"
                                style="width:30px; height:auto; border:0px; background:transparent;"
                                title="In báo cáo" type="button">
                            <i class="fa fa-print" style="font-size: 18px; color: #555;"></i>
                        </button>
                    </div>

                    <div style="text-align: center; margin-bottom: 25px;">
                        <h3 style="font-weight: bold; text-transform: uppercase; font-size: 20px;">
                            BÁO CÁO TỔNG [HỌC SINH/GIÁO VIÊN] HÀNG THÁNG
                        </h3>
                    </div>

                    <table class="data-table">
                        <thead>
                            <tr>
                                <t t-foreach="table_data[0]" t-as="header">
                                    <th><t t-esc="header"/></th>
                                </t>
                            </tr>
                        </thead>
                        <tbody>
                            <t t-foreach="table_data[1:]" t-as="row">
                                <tr>
                                    <t t-foreach="row" t-as="cell">
                                        <td t-att-style="cell_index == 0 and 'text-align: center;' or 'text-align: right;'">
                                            <t t-esc="cell"/>
                                        </td>
                                    </t>
                                </tr>
                            </t>
                        </tbody>
                    </table>

                </div>

                <style>
                    /* --- 1. ÉP KHỔ GIẤY A4 DỌC VÀ LỀ CHUẨN --- */
                    @page {
                        size: A4 portrait; /* Nếu báo cáo của anh bị nhiều cột quá, hãy đổi chữ portrait thành landscape nhé */
                        margin: 10mm 10mm 10mm 10mm !important;
                    }

                    /* --- 2. ÉP FONT ARIAL CHỐNG LỖI CHỮ, NHƯNG THA CHO ICON --- */
                    *:not(i) {
                        font-family: Arial, sans-serif !important;
                    }

                    /* --- 3. ẨN NÚT KHI IN --- */
                    @media print {
                        .d-print-none {
                            display: none !important;
                        }
                        body, .page {
                            margin-top: 0px !important;
                            padding-top: 0px !important;
                        }
                    }

                    /* --- 4. CSS BẢNG BIỂU --- */
                    .data-table {
                        border-collapse: collapse;
                        width: 100%;
                        font-size: 14px;
                    }

                    .data-table th, .data-table td {
                        border: 1px solid #444;
                        padding: 8px;
                    }

                    .data-table th {
                        background-color: #f2f2f2;
                        color: #212529; /* Đã thêm dấu chấm phẩy */
                        font-size: 15px;
                        font-weight: bold;
                        text-align: center; /* Tiêu đề cho ra giữa hết cho đẹp */
                    }

                    .data-table td {
                        width: 15%; /* Đã sửa lỗi sai chính tả widht */
                    }

                    /* Màu nền đan xen */
                    .data-table tbody tr:nth-child(even) {
                        background-color: #f8f9fa;
                    }

                    /* Bôi đậm dòng tổng cộng cuối cùng (nếu có) */
                    .data-table tbody tr:last-child {
                        font-weight: bold;
                        background-color: #e9ecef;
                    }
                </style>
            </t>
        </t>
    </template>
</odoo>